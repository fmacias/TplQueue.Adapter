<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
	<Version>1.0.0</Version>
    <PackageId>Fmacias.TplQueue</PackageId>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Cache\**" />
    <Compile Remove="Observers\**" />
    <EmbeddedResource Remove="Cache\**" />
    <EmbeddedResource Remove="Observers\**" />
    <None Remove="Cache\**" />
    <None Remove="Observers\**" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Cache\MemCache.cs" />
    <Compile Include="Observers\DirectObserverDispatcher.cs" />
    <Compile Include="Observers\LoggingObserverFactoryExtensions.cs" />
    <Compile Include="Observers\LoggingObserver.cs" />
    <Compile Include="Observers\ConsoleObserver.cs" />
    <Compile Include="Observers\FileLoggingObserver.cs" />
    <Compile Include="Observers\ProfilingObserver.cs" />
  </ItemGroup>
	<ItemGroup>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>Fmacias.TplQueue.Test</_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>
	
	<ItemGroup>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>Fmacias.TplQueue.Integration.Test</_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>
	
	<ItemGroup>
	  <Folder Include="Documentation\" />
	</ItemGroup>
	
	<ItemGroup>
	  <PackageReference Include="Fmacias.TplQueue.Cache.Abstract" Version="1.0.0" />
	  <PackageReference Include="Fmacias.TplQueue.Log" Version="1.0.0" />
	  <PackageReference Include="Fmacias.TplQueue.RetryPolicies" Version="1.0.0" />
	  <PackageReference Include="Fmacias.TplQueue.Serialization.SystemTextJson" Version="1.0.0" />
	  <PackageReference Include="Fmacias.TplQueue.Observers.ViewModel" Version="1.0.0" />
	</ItemGroup>
</Project>
