<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

	<!-- Variables for reuse -->
	<variable name="logDir" value="${basedir}/logs" />
	<variable name="logFile" value="${logDir}/integration-tests.log" />
	<variable name="layout"
			  value="${longdate}|${level:uppercase=true}|${logger}|${message}${onexception:inner=${newline}${exception:format=ToString}}" />

	<targets>
		<!-- Console target -->
		<target xsi:type="Console"
				name="console"
				layout="${layout}" />

		<!-- File target concurrentWrites="true" -->
		<target xsi:type="File"
				name="file"
				fileName="${logFile}"
				layout="${layout}"
				createDirs="true"
				keepFileOpen="false"
				archiveNumbering="Sequence"
				maxArchiveFiles="5"
				archiveAboveSize="10485760"
				autoFlush="true" />
	</targets>

	<rules>
		<!-- Write to both console + file -->
		<logger name="*" minlevel="Debug" writeTo="console,file" />
	</rules>
</nlog>
